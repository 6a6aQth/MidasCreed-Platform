generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Prospect {
  id               String   @id @default(cuid())
  name             String
  tier             String   // "malawi_simple" | "african_medium" | "international_high_end"
  sector           String?
  country          String?
  source           String   // "sourced" | "referral" | "existing_client" | "cold_outreach" | "inbound"
  assignedTo       String   // "Michaels" | "Conrad"
  fitScore         Int?     // 0-5
  signalScore      Int?     // 0-5
  createdAt        DateTime @default(now())

  contactChannel   String?  // "Email" | "LinkedIn" | "WhatsApp DM"
  firstContactDate DateTime?

  followUp1Date    DateTime?
  followUp1Done    Boolean  @default(false)
  followUp2Date    DateTime?
  followUp2Done    Boolean  @default(false)
  breakupDate      DateTime?
  breakupDone      Boolean  @default(false)

  replied          Boolean  @default(false) // true halts the follow-up sequence regardless of stage

  meetingDate      DateTime?
  meetingTime      DateTime? // exact date+time of the meeting
  meetingType      String?   // "video" | "phone" | "physical"
  meetingLocation  String?   // Video Link, Phone Number, or Address depending on type
  meetingDone      Boolean  @default(false)

  outcome          String?  // "dead_lead" | "agent_work" | "ai_audit"
  agentDescription String?  // what's being built — relevant once outcome is agent_work or ai_audit

  reportUrl        String?  // URL to external PDF report
  notes            String?
  updatedAt        DateTime @updatedAt

  payments         Payment[]
}

model Payment {
  id           String   @id @default(cuid())
  prospectId   String
  prospect     Prospect @relation(fields: [prospectId], references: [id])
  type         String   // "one_time" | "monthly_retainer"
  amount       Decimal
  currency     String   // "MWK" | "USD"
  invoiced     Boolean  @default(false)
  paid         Boolean  @default(false)
  date         DateTime @default(now())
}
